# Swipess Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to source control

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Deployment Scripts
# Used by execution/deploy_edge_function.py
SUPABASE_PROJECT_REF="your-supabase-project-ref-id"
# SUPABASE_FUNCTION_SLUG="ai-orchestrator"  # optional, defaults to ai-orchestrator
# SUPABASE_FUNCTION_PATH="supabase/functions/ai-orchestrator/index.ts"  # optional

# Web Push (VAPID) Keys
# Generate with: node -e "const c=require('crypto');const {privateKey:pr,publicKey:pu}=c.generateKeyPairSync('ec',{namedCurve:'P-256',publicKeyEncoding:{type:'spki',format:'der'},privateKeyEncoding:{type:'sec1',format:'der'}});console.log('pub='+pu.subarray(27).toString('base64url'));console.log('priv='+pr.subarray(7,39).toString('base64url'));"
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# MiniMax AI API Key for Swipess Assistant
MINIMAX_API_KEY="your-minimax-api-key"
